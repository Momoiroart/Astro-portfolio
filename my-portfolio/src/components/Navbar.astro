---
// Get the current page URL to highlight the active nav link
const currentPath = Astro.url.pathname;

// Helper function to check if path matches (handles /about, /about/, etc)
const isActive = (path: string) => {
  return currentPath === path || currentPath === path + '/';
};
---
<nav id="navbar" transition:persist>
  <div class="nav-inner">
    <a href="/" id="logo">momoiroart</a>

    <ul id="nav-links">
      <li><a href="/" class={isActive('/') ? 'nav-active' : ''}>Home</a></li>
      <li><a href="/about" class={isActive('/about') ? 'nav-active' : ''}>About</a></li>
      <li><a href="/projects" class={isActive('/projects') ? 'nav-active' : ''}>Projects</a></li>
    </ul>
  </div>
</nav>

<style>
  #navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    background: rgba(5, 3, 15, 0.9);
    backdrop-filter: blur(12px);
    z-index: 100;
    border-bottom: 1px solid rgba(124, 79, 208, 0.15);
  }

  /* Inner container limits width and centers everything */
  .nav-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 1rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  #logo {
    color: #ff6b9d;
    text-decoration: none;
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  #nav-links {
    list-style: none;
    display: flex;
    gap: 2.5rem;
    margin: 0;
    padding: 0;
  }

  #nav-links a {
    color: #b48fff;
    text-decoration: none;
    font-size: 0.95rem;
    transition: color 0.3s ease;
    padding-bottom: 4px;
    border-bottom: 2px solid transparent;
  }

  #nav-links a:hover {
    color: #4af0e8;
  }

  #nav-links a.nav-active {
    color: #4af0e8;
    border-bottom: 2px solid #4af0e8;
  }
</style>

<script>
  // Update active nav link after every page transition
  // (needed because transition:persist keeps the navbar alive across pages)
  function updateActiveLink() {
    const path = window.location.pathname;
    const links = document.querySelectorAll('#nav-links a');

    links.forEach(link => {
      const href = link.getAttribute('href');
      // Check if this link matches the current page
      const isActive = href === path || href === path.replace(/\/$/, '');
      link.classList.toggle('nav-active', isActive);
    });
  }

  // Run on first load
  updateActiveLink();

  // Run after every Astro page transition
  document.addEventListener('astro:page-load', updateActiveLink);
</script>