---
// Get the current page URL to highlight the active nav link
const currentPath = Astro.url.pathname;
---
<nav id="navbar" transition:persist>
  <a href="/" id="logo">momoiroart</a>

  <ul id="nav-links">
    <li><a href="/" class={currentPath === '/' ? 'nav-active' : ''}>Home</a></li>
    <li><a href="/about" class={currentPath === '/about/' || currentPath === '/about' ? 'nav-active' : ''}>About</a></li>
    <li><a href="/projects" class={currentPath === '/projects/' || currentPath === '/projects' ? 'nav-active' : ''}>Projects</a></li>
  </ul>
</nav>

<style>
  #navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 2rem;
    background: rgba(5, 3, 15, 0.9);
    backdrop-filter: blur(12px);
    z-index: 100;
    border-bottom: 1px solid rgba(124, 79, 208, 0.15);
  }

  #logo {
    color: #ff6b9d;
    text-decoration: none;
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  #nav-links {
    list-style: none;
    display: flex;
    gap: 2rem;
    margin: 0;
    padding: 0;
  }

  #nav-links a {
    color: #b48fff;
    text-decoration: none;
    font-size: 0.95rem;
    transition: color 0.3s ease;
    padding-bottom: 4px;
    border-bottom: 2px solid transparent;
  }

  #nav-links a:hover {
    color: #4af0e8;
  }

  #nav-links a.nav-active {
    color: #4af0e8;
    border-bottom: 2px solid #4af0e8;
  }
</style>
