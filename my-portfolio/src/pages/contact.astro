---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <section id="contact">

    <p class="section-label">Get In Touch</p>
    <h1 class="section-title" transition:name="page-title">Contact Me</h1>
    <p class="section-text" data-animate>
      Whether you want to collaborate on a project, have a question about my work,
      or just want to say hi — feel free to reach out. I'm always open to new ideas.
    </p>

    <!-- CONTACT OPTIONS -->
    <div id="contact-grid" data-animate>

      <a href="mailto:medypn.work@pm.me" class="contact-card">
        <div class="contact-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
        </div>
        <div class="contact-info">
          <span class="contact-label">Email</span>
          <span class="contact-value">medypn.work@pm.me</span>
        </div>
      </a>

      <a href="https://github.com/Momoiroart" target="_blank" class="contact-card">
        <div class="contact-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
          </svg>
        </div>
        <div class="contact-info">
          <span class="contact-label">GitHub</span>
          <span class="contact-value">Momoiroart</span>
        </div>
      </a>

      <a href="https://www.linkedin.com/in/pakaphon-suksena-4055b0326" target="_blank" class="contact-card">
        <div class="contact-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </div>
        <div class="contact-info">
          <span class="contact-label">LinkedIn</span>
          <span class="contact-value">Pakaphon Suksena</span>
        </div>
      </a>

      <a href="https://x.com/NobeMomoiro" target="_blank" class="contact-card">
        <div class="contact-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </div>
        <div class="contact-info">
          <span class="contact-label">X / Twitter</span>
          <span class="contact-value">@NobeMomoiro</span>
        </div>
      </a>

      <a href="https://linktr.ee/NobeMomoiro" target="_blank" class="contact-card">
        <div class="contact-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
            <path d="M7.953 15.066c-.08.163-.08.324-.08.486.08.517.528.897 1.052.897h2.107v4.464c0 .647.51 1.168 1.164 1.168h.568c.655 0 1.164-.521 1.164-1.168v-4.464h2.107c.527 0 .975-.38 1.052-.897.08-.488-.243-.975-.729-1.138l-3.917-3.483a.592.592 0 0 0-.812 0L7.953 15.066zM12 2.4a.6.6 0 0 0-.6.6v5.4H9.6a.6.6 0 0 0-.424 1.024l2.4 2.4a.6.6 0 0 0 .848 0l2.4-2.4A.6.6 0 0 0 14.4 8.4h-1.8V3a.6.6 0 0 0-.6-.6z"/>
          </svg>
        </div>
        <div class="contact-info">
          <span class="contact-label">Linktree</span>
          <span class="contact-value">NobeMomoiro</span>
        </div>
      </a>

    </div>

    <!-- SIMPLE MAILTO FORM -->
    <div id="message-box" data-animate>
      <h2 class="message-title">Send a Message</h2>
      <p class="message-sub">Clicking send will open your email client with your message pre-filled.</p>
      <form id="contact-form">
        <div class="form-group">
          <label for="subject">Subject</label>
          <input type="text" id="subject" placeholder="What's this about?" />
        </div>
        <div class="form-group">
          <label for="message">Message</label>
          <textarea id="message" rows="5" placeholder="Write your message here..."></textarea>
        </div>
        <button type="submit" class="btn-send">Send via Email</button>
      </form>
    </div>

  </section>
</Layout>

<script>
  const form = document.getElementById('contact-form');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const subject = (document.getElementById('subject') as HTMLInputElement)?.value || 'Hello!';
    const message = (document.getElementById('message') as HTMLTextAreaElement)?.value || '';
    window.location.href = `mailto:medypn.work@pm.me?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(message)}`;
  });
</script>

<style>

  #contact {
    max-width: 800px;
    margin: 0 auto;
    padding: 8rem 2rem 6rem 2rem;
    min-height: 100vh;
  }

  .section-label {
    color: var(--cyan);
    font-size: 0.9rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-family: 'Space Mono', monospace;
    margin: 0 0 0.5rem 0;
  }

  .section-title {
    color: var(--text-strong);
    font-size: 3rem;
    font-weight: 700;
    margin: 0 0 1.5rem 0;
  }

  .section-text {
    color: var(--text);
    font-size: 1.05rem;
    line-height: 1.8;
    max-width: 560px;
    margin: 0 0 3rem 0;
  }

  /* CONTACT CARDS GRID */
  #contact-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin-bottom: 3rem;
  }

  .contact-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .contact-card:hover {
    border-color: var(--cyan);
    transform: translateY(-3px);
    background: rgba(74, 240, 232, 0.05);
  }

  .contact-icon {
    color: var(--lavender);
    flex-shrink: 0;
    transition: color 0.3s ease;
  }

  .contact-card:hover .contact-icon {
    color: var(--cyan);
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .contact-label {
    color: var(--text);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-family: 'Space Mono', monospace;
  }

  .contact-value {
    color: var(--text-strong);
    font-size: 0.95rem;
    font-weight: 500;
  }

  /* MESSAGE FORM */
  #message-box {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2rem;
  }

  .message-title {
    color: var(--text-strong);
    font-size: 1.4rem;
    font-weight: 700;
    margin: 0 0 0.4rem 0;
  }

  .message-sub {
    color: var(--text);
    font-size: 0.9rem;
    margin: 0 0 1.5rem 0;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 1.2rem;
  }

  .form-group label {
    color: var(--lavender);
    font-size: 0.85rem;
    font-family: 'Space Mono', monospace;
  }

  .form-group input,
  .form-group textarea {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    color: var(--text-strong);
    font-family: 'Outfit', sans-serif;
    font-size: 0.95rem;
    resize: vertical;
    transition: border-color 0.2s ease;
    outline: none;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    border-color: var(--cyan);
  }

  .btn-send {
    background: linear-gradient(135deg, var(--pink), var(--violet));
    color: var(--text-strong);
    border: none;
    padding: 0.75rem 2rem;
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.2s ease, transform 0.2s ease;
    font-family: 'Outfit', sans-serif;
  }

  .btn-send:hover {
    opacity: 0.85;
    transform: translateY(-2px);
  }

  @media (max-width: 600px) {
    #contact-grid { grid-template-columns: 1fr; }
  }
</style>
