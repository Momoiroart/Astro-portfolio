<!-- TYPING EFFECT SCRIPT -->
<script>
  const roles = [
    "Web Developer.",
    "Roblox Creator.",
    "Game Developer.",
    "Educator.",
    "Discord Bot Dev.",
    "Python Enthusiast."
  ];

  let roleIndex = 0;
  let charIndex = 0;
  let isDeleting = false;
  const typedRole = document.getElementById('typed-role');

  function typeEffect() {
    if (!typedRole) return;

    const currentRole = roles[roleIndex];

    if (!isDeleting) {
      // Typing forward
      typedRole.textContent = currentRole.substring(0, charIndex + 1);
      charIndex++;

      if (charIndex === currentRole.length) {
        // Pause at end of word, then start deleting
        isDeleting = true;
        setTimeout(typeEffect, 1500);
        return;
      }
    } else {
      // Deleting backward
      typedRole.textContent = currentRole.substring(0, charIndex - 1);
      charIndex--;

      if (charIndex === 0) {
        isDeleting = false;
        roleIndex = (roleIndex + 1) % roles.length;
      }
    }

    // Typing speed: faster when deleting
    const speed = isDeleting ? 50 : 100;
    setTimeout(typeEffect, speed);
  }

  // Start the typing effect
  typeEffect();
</script>

<style>
  :root {
    --pink: #ff6b9d;
    --cyan: #4af0e8;
    --void: #05030f;
    --violet: #7c4fd0;
    --lavender: #b48fff;
  }

  #hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 5rem 2rem 2rem 2rem;
    max-width: 800px;
    margin: 0 auto;
    /* Fade in on page load */
    animation: fadeInUp 0.6s ease both;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  #greeting {
    color: var(--cyan);
    font-size: 1rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-family: 'Space Mono', monospace;
    margin: 0 0 0.5rem 0;
  }

  #name {
    color: white;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 700;
    margin: 0 0 0.25rem 0;
    line-height: 1.1;
    background: linear-gradient(135deg, var(--pink), var(--lavender));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  #handle {
    color: var(--lavender);
    font-size: 1.1rem;
    margin: 0 0 1.5rem 0;
    font-family: 'Space Mono', monospace;
  }

  /* TYPING EFFECT STYLES */
  #typed-text {
    color: #a0a0b0;
    font-size: 1.2rem;
    line-height: 1.6;
    margin: 0 0 2rem 0;
  }

  #typed-role {
    color: var(--cyan);
    font-weight: 600;
    border-right: 2px solid var(--cyan);
    padding-right: 4px;
    animation: blink 0.8s infinite;
  }

  @keyframes blink {
    0%, 100% { border-color: var(--cyan); }
    50% { border-color: transparent; }
  }

  /* INLINE NAV FOR HOME PAGE */
  #home-nav {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  #home-nav a {
    color: var(--lavender);
    text-decoration: none;
    font-size: 1rem;
    font-weight: 500;
    padding: 0.4rem 0.8rem;
    border-radius: 6px;
    background: rgba(124, 79, 208, 0.15);
    border: 1px solid rgba(124, 79, 208, 0.3);
    transition: all 0.2s ease;
  }

  #home-nav a:hover {
    background: rgba(124, 79, 208, 0.3);
    color: var(--cyan);
    border-color: var(--cyan);
    transform: translateY(-2px);
  }

  #home-nav a.nav-active {
    background: rgba(74, 240, 232, 0.15);
    color: var(--cyan);
    border-color: var(--cyan);
  }

  .nav-sep {
    color: var(--violet);
  }

  #tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: 2.5rem;
  }

  .tag {
    background: transparent;
    border: 1px solid var(--violet);
    color: var(--lavender);
    padding: 0.3rem 0.8rem;
    border-radius: 999px;
    font-size: 0.85rem;
    font-family: 'Space Mono', monospace;
    transition: all 0.2s ease;
  }

  .tag:hover {
    border-color: var(--pink);
    color: var(--pink);
  }

  #buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  #buttons a {
    padding: 0.75rem 1.75rem;
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--pink), var(--violet));
    color: white;
  }

  .btn-primary:hover {
    opacity: 0.85;
    transform: translateY(-2px);
  }

  .btn-secondary {
    background: transparent;
    color: var(--cyan);
    border: 1px solid var(--cyan);
  }

  .btn-secondary:hover {
    background: var(--cyan);
    color: var(--void);
    transform: translateY(-2px);
  }

  /* SOCIAL ICONS ROW */
  #social-links {
    display: flex;
    gap: 1rem;
    margin-top: 1.5rem;
    align-items: center;
  }

