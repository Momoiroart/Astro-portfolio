---
// Layout.astro - The wrapper that every page uses
// Think of this as the picture FRAME - every page puts its content inside here
// <slot /> is the empty space where each page's content appears
import Navbar from "../components/Navbar.astro"
---

<!doctype html>
<html lang="en">
  <head>
    <!-- META TAGS: Technical info about the page - not visible to users -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />  <!-- makes it mobile-friendly -->

    <!-- FAVICON: The small icon in the browser tab -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- PAGE TITLE: Shows in the browser tab -->
    <title>Pakaphon Suksena — momoiro workshop</title>

    <!-- GOOGLE FONTS: Load your brand fonts from the internet -->
    <!-- We load them here in the Layout so ALL pages get the same fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet" />
  </head>

  <body>
    <!-- SLOT: This is where each page's content goes -->
    <!-- When index.astro wraps content in <Layout>, it appears here -->
     <Navbar />
    <slot />
  </body>
</html>

<style>
  /* GLOBAL STYLES: These apply to the ENTIRE site, every page */
  /* Because this is the Layout, styles here are shared everywhere */

  /* CSS RESET: Remove browser default spacing */
  *, *::before, *::after {
    box-sizing: border-box; /* makes sizing more predictable */
  }

  html, body {
    margin: 0;               /* remove default white space around edges */
    padding: 0;
    width: 100%;
    min-height: 100%;
    background-color: #05030f; /* --void color: deep dark background */
    font-family: 'Outfit', sans-serif; /* default font for all text */
    color: white;
  }
</style>
