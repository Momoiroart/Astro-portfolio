---
// Layout.astro - The wrapper for every page
// VIEW TRANSITIONS: Makes page switches feel like a SPA (no reload)
// isHome prop: when true, hides the top navbar (homepage has its own nav)
import Navbar from "../components/Navbar.astro"
import { ClientRouter } from "astro:transitions";

const { isHome = false } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Pakaphon Suksena — momoiro workshop</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet" />

    <!-- VIEW TRANSITIONS: This one line enables smooth page transitions -->
    <ClientRouter />
  </head>

  <body>
    {!isHome && <Navbar />}
    <main transition:animate="slide">
      <slot />
    </main>
  </body>
</html>

<style>
  *, *::before, *::after {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    padding: 0;
    width: 100%;
    min-height: 100vh;
    background-color: #05030f;
    font-family: 'Outfit', sans-serif;
    color: white;
  }

  main {
    min-height: 100vh;
  }
</style>
